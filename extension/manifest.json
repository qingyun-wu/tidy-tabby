{
  "manifest_version": 3,
  "name": "Tidy Tabby",
  "version": "1.0.0",
  "description": "Tidy Tabby keeps your tabs tidy. New tab page that groups your open tabs by domain and lets you close them with style.",
  "permissions": ["tabs", "activeTab", "storage", "bookmarks", "history", "nativeMessaging"],
  "host_permissions": ["https://api.anthropic.com/*"],
  "chrome_url_overrides": { "newtab": "index.html" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Tidy Tabby",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
